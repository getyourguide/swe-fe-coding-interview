{
  "name": "fe-tech-challenge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "format": "prettier --write .",
    "ai:run": "node --import tsx scripts/agent.ts",
    "ai:a11y": "npm run ai:run -- --task a11y",
    "ai:tests": "npm run ai:run -- --task tests",
    "ai:pr": "npm run ai:run -- --task pr",
    "ai:best-practices": "npm run ai:run -- --task best-practices",
    "ai:all": "npm run ai:run -- --task all"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.4.2",
    "pinia": "^3.0.3",
    "simple-git": "^3.28.0",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.16.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "jsdom": "^25.0.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "~5.6.3",
    "vite": "^6.4.2",
    "vite-plugin-vue-devtools": "^7.7.7",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.0.3"
  },
  "pnpm": {
    "overrides": {
      "glob@>=10.2.0 <10.5.0": "10.5.0",
      "minimatch@<9.0.7": "9.0.7",
      "rollup@>=4.0.0 4.59.0": "4.59.0",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "brace-expansion@>=4.0.0 <5.0.5": "5.0.5"
    }
  }
}
